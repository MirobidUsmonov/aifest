---
import EcomStamp from './EcomStamp.astro';
interface Props {
  id?: string;
  number: string; // "01"
  eyebrow: string; // "ABOUT"
  title?: string;
  align?: 'left' | 'center';
}
const { id, number, eyebrow, title, align = 'left' } = Astro.props;
---
<div id={id} class="relative">
  <div class="border-t border-rule"></div>
  <div class:list={['flex items-start justify-between gap-6 pt-6 pb-10', align === 'center' && 'flex-col items-center text-center']}>
    <div class="flex items-center gap-4">
      <span class="font-mono uppercase tracking-[0.18em] text-[11px] text-gold">S/{number} — {eyebrow}</span>
    </div>
    <EcomStamp size="sm" center={number} arcTop={`AI FEST '26`} arcBottom={eyebrow} />
  </div>
  {title && (
    <h2 class:list={['font-display font-black leading-[0.92] tracking-tightest text-ink text-4xl sm:text-5xl md:text-6xl lg:text-7xl mb-12', align === 'center' && 'text-center']}>{title}</h2>
  )}
</div>
